{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug NestJS Backend (开发模式)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/node_modules/@nestjs/cli/bin/nest.js",
      "args": ["start", "--debug", "--watch"],
      "env": {
        "NODE_ENV": "development"
      },
      "envFile": "${workspaceFolder}/backend/.env",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "restart": true,
      "protocol": "inspector",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/backend/dist/**/*.js"
      ],
      "presentation": {
        "hidden": false,
        "group": "Backend",
        "order": 1
      },
      "preLaunchTask": "Backend: Prisma Generate"
    },
    {
      "name": "Debug NestJS Backend (生产模式)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/dist/main.js",
      "env": {
        "NODE_ENV": "production"
      },
      "envFile": "${workspaceFolder}/backend/.env",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "presentation": {
        "hidden": false,
        "group": "Backend",
        "order": 2
      },
      "preLaunchTask": "Backend: Build"
    },
    {
      "name": "Debug Backend Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/node_modules/.bin/jest",
      "args": [
        "--runInBand",
        "--no-cache",
        "--watch"
      ],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "NODE_ENV": "test"
      },
      "envFile": "${workspaceFolder}/backend/.env",
      "presentation": {
        "hidden": false,
        "group": "Backend Testing",
        "order": 1
      }
    },
    {
      "name": "Debug Backend E2E Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/node_modules/.bin/jest",
      "args": [
        "--config",
        "./test/jest-e2e.json",
        "--runInBand",
        "--detectOpenHandles",
        "--forceExit"
      ],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "NODE_ENV": "test"
      },
      "envFile": "${workspaceFolder}/backend/.env",
      "presentation": {
        "hidden": false,
        "group": "Backend Testing",
        "order": 2
      }
    },
    {
      "name": "Launch Flutter App (Debug)",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/frontend/lib/main.dart",
      "cwd": "${workspaceFolder}/frontend",
      "args": [
        "--debug"
      ],
      "presentation": {
        "hidden": false,
        "group": "Frontend",
        "order": 1
      }
    },
    {
      "name": "Attach to NestJS Process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/backend/dist/**/*.js"
      ],
      "presentation": {
        "hidden": false,
        "group": "Backend",
        "order": 3
      }
    }
  ],
  "compounds": [
    {
      "name": "Launch Full Stack (Backend + Frontend)",
      "configurations": [
        "Debug NestJS Backend (开发模式)",
        "Launch Flutter App (Debug)"
      ],
      "presentation": {
        "hidden": false,
        "group": "Full Stack",
        "order": 1
      }
    }
  ]
}
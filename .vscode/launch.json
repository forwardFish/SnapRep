  ],
  "compounds": [
    {
      "name": "全栈调试 (后端 + 前端 Windows)",
      "configurations": [
        "Debug NestJS Backend (开发模式)",
        "Flutter Debug (Windows)"
      ],
      "presentation": { "hidden": false, "group": "Full Stack", "order": 1 },
      "stopAll": true
    },
    {
      "name": "全栈调试 (后端 + 前端 Chrome)",
      "configurations": [
        "Debug NestJS Backend (开发模式)",
        "Flutter Debug (Chrome)"
      ],
      "presentation": { "hidden": false, "group": "Full Stack", "order": 2 },
      "stopAll": true
    }
  ]
}

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug NestJS Backend (开发模式)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["start:dev"],
      "env": { "NODE_ENV": "development" },
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal",

      // 关键：Nest CLI 会再起子进程跑应用；这个能自动附着
      "autoAttachChildProcesses": true,

      // 让断点绑定到编译后的 dist，并映射回 ts 源码
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/backend/dist/**/*.js"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/backend/dist/**/*.js",
        "!**/node_modules/**"
      ],

      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "Backend: Prisma Generate"
    },
    {
      "name": "Debug NestJS Backend (TypeScript编译)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["start:debug"],
      "env": { "NODE_ENV": "development" },
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true,
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/backend/dist/**/*.js"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/backend/dist/**/*.js",
        "!**/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "Backend: Prisma Generate"
    },

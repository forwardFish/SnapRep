    {
      "name": "Flutter Debug (Windows)",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/frontend/lib/main.dart",
      "cwd": "${workspaceFolder}/frontend",
      "args": ["--target", "${workspaceFolder}/frontend/lib/main.dart"],
      "deviceId": "windows",
      "presentation": { "hidden": false, "group": "Frontend", "order": 1 }
    },
    {
      "name": "Flutter Debug (Chrome)",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/frontend/lib/main.dart",
      "cwd": "${workspaceFolder}/frontend",
      "args": ["--target", "${workspaceFolder}/frontend/lib/main.dart"],
      "deviceId": "chrome",
      "presentation": { "hidden": false, "group": "Frontend", "order": 2 }
    },
    {
      "name": "Flutter Profile (性能分析)",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/frontend/lib/main.dart",
      "cwd": "${workspaceFolder}/frontend",
      "args": ["--profile"],
      "flutterMode": "profile",
      "presentation": { "hidden": false, "group": "Frontend", "order": 3 }
    },
    {
      "name": "Flutter Run Windows (命令行方式)",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/frontend/lib/main.dart",
      "cwd": "${workspaceFolder}/frontend",
      "args": ["--debug"],
      "deviceId": "windows",
      "console": "terminal",
      "presentation": { "hidden": false, "group": "Frontend", "order": 4 }
    },
    {
      "name": "Attach to Flutter (连接到已运行的Flutter应用)",
      "type": "dart",
      "request": "attach",
      "cwd": "${workspaceFolder}/frontend",
      "presentation": { "hidden": false, "group": "Frontend", "order": 5 }
    },

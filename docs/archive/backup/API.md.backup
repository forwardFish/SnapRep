### 4.2 Calculate Rarity (计算稀有度)

**用途**: 计算器材组合的稀有度等级

```typescript
GET /api/v1/rarity/calculate/{equipmentCode}
```

**Implementation**: NestJS

**Why NestJS**: 需要查询全局统计数据、计算频次排名

**Request**:
```
GET /api/v1/rarity/calculate/chair?scenario=office&userId=user-123
```

**Response**:
```json
{
  "equipmentCode": "chair",
  "currentRarity": {
    "level": "COMMON",
    "score": 0.85,               // 0-1, 越小越稀有
    "globalRank": 2,              // 全球使用频次排名
    "dailyUsage": 15420,          // 今日全球使用次数
    "weeklyUsage": 89567          // 本周全球使用次数
  },
  "trends": {
    "lastWeek": "COMMON",
    "prediction": "UNCOMMON",     // 下周预测
    "changeReason": "Usage decreased by 15%"
  },
  "regionStats": {
    "region": "Asia",
    "regionRank": 1,
    "cityBonus": "Beijing Limited Edition"  // 城市彩蛋
  },
  "thresholds": {
    "LEGENDARY": 0.01,  // Top 1%
    "EPIC": 0.05,       // Top 5%
    "RARE": 0.15,       // Top 15%
    "UNCOMMON": 0.40,   // Top 40%
    "COMMON": 1.0       // Rest
  }
}
```

**Algorithm** (NestJS):
```typescript
@Injectable()
export class RarityService {
  async calculateRarity(params: RarityParams): Promise<RarityResult> {
    const { equipment, scenario, userId } = params;

    // 1. 查询全局7日频次 (从 equipment_frequencies 表)
    const globalStats = await this.prisma.equipmentFrequency.findMany({
      where: {
        equipmentCode: { in: equipment },
        date: { gte: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000) }
      }
    });

    // 2. 计算总使用次数
    const totalUsage = globalStats.reduce((sum, stat) => sum + stat.count, 0);

    // 3. 获取所有器材的总使用次数
    const allEquipmentUsage = await this.getTotalEquipmentUsage();

    // 4. 计算稀有度分数 (相对频次)
    const score = totalUsage / allEquipmentUsage;

    // 5. 确定稀有度等级
    let level: RarityLevel;
    if (score <= 0.01) level = 'LEGENDARY';
    else if (score <= 0.05) level = 'EPIC';
    else if (score <= 0.15) level = 'RARE';
    else if (score <= 0.40) level = 'UNCOMMON';
    else level = 'COMMON';

    // 6. 确定器材系列
    const series = this.getEquipmentSeries(equipment[0]);

    // 7. 检查城市彩蛋
    const cityBonus = await this.checkCityBonus(userId, scenario);

    return {
      level,
      score,
      equipmentSeries: series,
      globalRank: await this.getGlobalRank(equipment),
      cityBonus
    };
  }

  private getEquipmentSeries(equipmentCode: string): string {
    const seriesMap = {
      'chair': 'Furniture Series',
      'sofa': 'Furniture Series',
      'wall': 'Wall Series',
      'bottle': 'Bottle Series',
      'backpack': 'Carry Series',
      // ...
    };
    return seriesMap[equipmentCode] || 'Creative Series';
  }
}
```

---

### 4.3 Upload Card Image (上传卡片图片)

**用途**: 将生成的卡片图片上传到 Supabase Storage

**Implementation**: Supabase Storage API

**Frontend Usage**:
```dart
// 上传卡片图片
Future<String> uploadCardImage(Uint8List imageBytes, String userId, String sessionId) async {
  final fileName = '$userId/$sessionId.png';

  final response = await supabase.storage
    .from('share-cards')
    .uploadBinary(fileName, imageBytes);

  if (response.error != null) {
    throw Exception('Failed to upload card image');
  }

  // 获取公开 URL
  final publicUrl = supabase.storage
    .from('share-cards')
    .getPublicUrl(fileName);

  return publicUrl;
}
```

**Storage Bucket Configuration**:
```sql
-- Supabase Storage bucket setup
INSERT INTO storage.buckets (id, name, public)
VALUES ('share-cards', 'share-cards', true);

-- RLS policy: 用户只能上传自己的卡片
CREATE POLICY "Users can upload own cards" ON storage.objects
FOR INSERT TO authenticated
USING (
  bucket_id = 'share-cards' AND
  (storage.foldername(name))[1] = auth.uid()::text
);

-- RLS policy: 所有人可以查看公开卡片
CREATE POLICY "Public cards are viewable" ON storage.objects
FOR SELECT TO anon, authenticated
USING (bucket_id = 'share-cards');
```


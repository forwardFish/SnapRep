### 4.1 Generate Share Card (生成分享卡片)

**用途**: 训练完成后生成成果卡片

```typescript
POST /api/v1/cards/generate
```

**Implementation**: NestJS + Canvas/Sharp

**Why NestJS**: 图像合成、稀有度计算、数据聚合等复杂逻辑

**Request**:
```json
{
  "sessionId": "session-456",
  "template": "classic",          // "classic" | "minimal" | "vibrant"
  "style": {
    "hideRealPhotos": true,       // 使用插画而非实拍
    "autoBlurFaces": true,        // 自动人脸模糊
    "customText": "Keep going!"   // 可选: 自定义文案
  }
}
```

**Response**:
```json
{
  "cardId": "card-789",
  "cardImageUrl": "https://storage.supabase.co/share-cards/user123/card-789.png",

  // 稀有度信息
  "rarity": {
    "level": "RARE",               // COMMON | UNCOMMON | RARE | EPIC | LEGENDARY
    "score": 0.15,                 // 稀有度分数 (0-1, 越小越稀有)
    "equipmentSeries": "Furniture Series",
    "specialTags": ["Silent Mode", "7-Day Streak"],
    "cityEdition": null            // 城市限定 (如 "Beijing Limited")
  },

  // 卡片元数据
  "metadata": {
    "totalDuration": 180,
    "exercisesCompleted": 3,
    "streak": 7,
    "equipmentUsed": ["chair", "wall"],
    "scenario": "office",
    "difficulty": "BEGINNER",
    "benefits": [
      "Relieves neck stiffness",
      "Opens upper back mobility",
      "Stabilizes core muscles"
    ]
  },

  // 分享文案
  "shareText": "I just completed a 3-min stretch workout using chair+wall and got a RARE card! 🎉 #SnapAnywhere #SnapRep",

  // DeepLink (一键同款)
  "deepLink": "snaprep://workout?equipment=chair,wall&intent=STRETCH&muscles=CHEST,BACK&ref=card-789",

  // 生成信息
  "generatedAt": "2024-10-30T10:37:00Z",
  "renderTime": 650  // 渲染耗时 (ms)
}
```

**Implementation Logic** (NestJS):
```typescript
@Injectable()
export class CardGenerationService {
  constructor(
    private prisma: PrismaService,
    private rarityService: RarityService,
    private storageService: StorageService
  ) {}

  async generateCard(dto: GenerateCardDto): Promise<ShareCardResponse> {
    // 1. 获取训练会话数据
    const session = await this.prisma.workoutSession.findUnique({
      where: { id: dto.sessionId },
      include: {
        sessionExercises: {
          include: { exercise: { include: { exerciseEquipment: true } } }
        },
        user: true
      }
    });

    // 2. 计算稀有度 (基于全局7日频次)
    const rarity = await this.rarityService.calculateRarity({
      equipment: session.equipment,
      scenario: session.scenario,
      userId: session.userId
    });

    // 3. 准备卡片数据
    const cardData = {
      equipment: session.equipment,
      scenario: session.scenario,
      rarity: rarity,
      benefits: session.sessionExercises.map(se => se.exercise.benefits),
      duration: session.actualDurationSec,
      streak: await this.getUserStreak(session.userId),
      specialTags: this.getSpecialTags(session)
    };

    // 4. 图像合成 (使用 Sharp 或 Canvas)
    const cardImage = await this.composeCardImage({
      template: dto.template,
      data: cardData,
      style: dto.style
    });

    // 5. 上传到 Supabase Storage
    const imageUrl = await this.storageService.uploadCardImage(
      cardImage,
      `${session.userId}/${dto.sessionId}.png`
    );

    // 6. 保存到数据库 (share_cards表)
    const shareCard = await this.prisma.shareCard.create({
      data: {
        userId: session.userId,
        sessionId: session.id,
        imageUrl: imageUrl,
        rarity: rarity.level,
        rarityScore: rarity.score,
        equipmentSeries: rarity.equipmentSeries,
        specialTags: cardData.specialTags,
        isPublic: true,
        template: dto.template
      }
    });

    // 7. 生成 DeepLink
    const deepLink = this.generateDeepLink(session);

    // 8. 格式化返回
    return {
      cardId: shareCard.id,
      cardImageUrl: imageUrl,
      rarity: rarity,
      metadata: cardData,
      shareText: this.generateShareText(cardData, rarity),
      deepLink: deepLink,
      generatedAt: new Date(),
      renderTime: performance.now() - startTime
    };
  }

  // 图像合成 (Sharp)
  private async composeCardImage(params: ComposeParams): Promise<Buffer> {
    const { template, data, style } = params;

    // 加载模板
    const templatePath = `./assets/templates/${template}.png`;
    let image = sharp(templatePath);

    // 添加器材图标
    const equipmentIcon = await this.getEquipmentIcon(data.equipment[0]);

    // 添加稀有度背景效果
    const rarityOverlay = await this.getRarityOverlay(data.rarity.level);

    // 合成图层
    image = image.composite([
      { input: rarityOverlay, gravity: 'center' },
      { input: equipmentIcon, gravity: 'north', top: 100 },
      // ... 添加文字、标签等
    ]);

    // 压缩输出
    return image
      .png({ quality: 90, compressionLevel: 9 })
      .toBuffer();
  }
}
```

**Frontend Usage**:
```dart
// ResultCardPage
class ResultCardPage extends StatefulWidget {

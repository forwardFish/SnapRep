## 🎪 WorkoutResultPage APIs

### Page Overview
- **Page Goal**: 展示精准匹配的3个动作，支持替换和跟练
- **Key Features**: 快速推荐, 动作替换, 候选列表, 跟练模式
- **Performance Target**: 推荐生成 <5秒

---

### 3.1 Quick Workout Recommendation (快速推荐)

**用途**: 根据用户引导选择，生成3个推荐动作

```typescript
POST /api/v1/recommendations/quick
```

**Implementation**: NestJS Complex Algorithm

**Why NestJS**: 复杂的多维匹配算法 (用户偏好、器材可用性、难度递进、部位均衡)

**Request**:
```json
{
  "userId": "user-123",              // 从 JWT token 自动提取
  "intent": "STRETCH",               // 可选: 运动意图 (RELAX | STRETCH | LIGHT_CARDIO | STRENGTH)
  "equipment": ["chair", "wall"],    // 可选: 可用器材 (默认: ["hands_free"])
  "scenario": "office",              // 可选: 场景代码
  "targetMuscles": ["NECK_SHOULDER"], // 可选: 目标部位 (最多2个)
  "duration": 60,                    // 可选: 总时长限制(秒) (默认: 60)
  "difficulty": "BEGINNER",          // 可选: 难度 (BEGINNER | INTERMEDIATE | ADVANCED)
  "excludeExerciseIds": [],          // 可选: 排除的动作ID (用于换一批)
  "themeWeekId": null,               // 可选: 主题周ID
  "isOffline": false                 // 是否离线模式
}
```

**Response**:
```json
{
  "sessionId": "session-456",        // 会话ID (已创建 workout_session 记录)
  "intent": "STRETCH",
  "totalDuration": 60,
  "difficulty": "BEGINNER",
  "exercises": [
    {
      "id": "exercise-001",
      "code": "wall_chest_opener",
      "name": "Wall Chest Opener",
      "duration": 20,
      "sets": 1,
      "restSeconds": 0,
      "difficulty": "BEGINNER",
      "primaryMuscle": "CHEST",
      "secondaryMuscles": ["SHOULDERS"],
      "intentType": "STRETCH",

      // 安全指导
      "keyPoints": [
        "Keep spine in neutral position",
        "Depress shoulders, don't shrug",
        "Move slowly and controlled"
      ],
      "safetyWarnings": [
        "Keep neck neutral, don't extend back",
        "Shoulders down, not shrugged"
      ],

      // 媒体资源
      "demoImageUrl": "https://storage.supabase.co/demos/wall_chest_opener.gif",
      "demoVideoUrl": null,
      "thumbnailUrl": "https://storage.supabase.co/thumbs/wall_chest_opener.jpg",

      // 标签
      "tags": ["standing", "wall", "stretch", "silent", "small_space"],

      // 器材
      "equipment": ["wall"],

      // 效果描述
      "benefits": "Relieves neck stiffness, relaxes shoulders",

      // 详细要领 (可折叠显示)
      "instructions": {
        "setup": "Stand facing a wall...",
        "execution": "Step 1: ..., Step 2: ...",
        "breathing": "Inhale as you...",
        "commonMistakes": ["Don't arch your back", "Don't shrug shoulders"]
      }
    },
    {
      "id": "exercise-002",
      "code": "chair_sit_to_stand",
      "name": "Chair Sit to Stand",
      // ... 相同结构
    },
    {
      "id": "exercise-003",
      "code": "core_plank_hold",
      "name": "Core Plank Hold",
      // ... 相同结构
    }
  ],

  // 替换候选 (6-9个)
  "alternatives": [
    {
      "id": "exercise-004",
      "code": "wall_shoulder_slide",
      "name": "Wall Shoulder Slide",
      "thumbnailUrl": "...",
      "difficulty": "BEGINNER",
      "primaryMuscle": "SHOULDERS",
      "tags": ["wall", "stretch", "silent"],
      "benefits": "Opens shoulders, improves posture"
    }
    // ... 5-8 more alternatives
  ],

  // 会话元数据
  "metadata": {
    "createdAt": "2024-10-30T10:30:00Z",
    "recommendationVersion": "v1.2",
    "algorithm": "smart_selection_v2"
  }
}
```

**Algorithm Logic** (NestJS Service):
```typescript
@Injectable()
export class WorkoutRecommendationService {
  async generateQuickRecommendation(dto: QuickRecommendationDto) {
    // 1. 获取用户偏好 (UserPreference表)
    const userPrefs = await this.getUserPreferences(dto.userId);

    // 2. 筛选可用动作 (基于器材、场景、意图)
    const availableExercises = await this.prisma.exercise.findMany({
      where: {
        isActive: true,
        intentType: dto.intent || undefined,
        exerciseEquipment: {
          some: {
            equipment: {
              code: { in: dto.equipment || ['hands_free'] }
            }
          }
        }
      },
      include: {
        exerciseEquipment: { include: { equipment: true } },
        exerciseScenarios: { include: { scenario: true } }
      }
    });

    // 3. 智能选择算法
    const selectedExercises = await this.smartSelection({
      exercises: availableExercises,
      userPrefs,
      constraints: {
        targetMuscles: dto.targetMuscles,
        difficulty: dto.difficulty,
        duration: dto.duration,
        excludeIds: dto.excludeExerciseIds
      }
    });

    // 智能选择规则:
    // - 避免重复 (检查用户最近7天训练历史)
    // - 难度递进 (第1个简单, 第2个中等, 第3个稍难)
    // - 部位均衡 (如果选了颈肩, 至少1个动作针对颈肩)
    // - 安全优先 (办公室场景过滤跳跃动作)
    // - 时长分配 (总和接近目标时长±10%)

    // 4. 创建训练会话
    const session = await this.prisma.workoutSession.create({
      data: {
        userId: dto.userId,
        status: 'PLANNED',
        intentType: dto.intent,
        difficulty: dto.difficulty,
        plannedDurationSec: dto.duration,
        themeWeekId: dto.themeWeekId,
        sessionExercises: {
          create: selectedExercises.map((ex, idx) => ({
            exerciseId: ex.id,
            position: idx + 1,
            plannedDurationSec: ex.duration,
            plannedSets: ex.sets
          }))
        }
      }
    });

    // 5. 生成替换候选 (6-9个)
    const alternatives = await this.generateAlternatives({
      exercises: availableExercises,
      selected: selectedExercises,
      count: 9
    });

    // 6. 格式化返回
    return this.formatResponse(session, selectedExercises, alternatives);
  }

  // 智能选择核心算法
  private async smartSelection(params: SelectionParams): Promise<Exercise[]> {
    const { exercises, userPrefs, constraints } = params;

    // 评分系统
    const scoredExercises = exercises.map(ex => ({
      exercise: ex,
      score: this.calculateScore(ex, userPrefs, constraints)
    }));

    // 排序并选择
    scoredExercises.sort((a, b) => b.score - a.score);

    // 贪心算法选择3个动作
    const selected = [];
    for (const item of scoredExercises) {
      if (selected.length >= 3) break;

      // 检查是否满足约束
      if (this.meetsConstraints(item.exercise, selected, constraints)) {
        selected.push(item.exercise);
      }
    }

    return selected;
  }
}
```

**Frontend Usage**:
```dart
// WorkoutResultPage
class WorkoutResultPage extends StatefulWidget {
  @override
  _WorkoutResultPageState createState() => _WorkoutResultPageState();
}

class _WorkoutResultPageState extends State<WorkoutResultPage> {
  List<Exercise> exercises = [];
  bool isLoading = true;

  @override
  void initState() {
    super.initState();
    loadRecommendation();
  }

  Future<void> loadRecommendation() async {
    setState(() => isLoading = true);

    final result = await apiService.getQuickRecommendation(
      intent: widget.intent,
      equipment: widget.equipment,
      scenario: widget.scenario,
      targetMuscles: widget.targetMuscles
    );

    setState(() {
      exercises = result['exercises'];
      alternatives = result['alternatives'];
      sessionId = result['session_id'];
      isLoading = false;
    });
  }

  @override
  Widget build(BuildContext context) {
    if (isLoading) return LoadingIndicator();

    return Column(
      children: [
        // 顶部信息条
        WorkoutInfoBar(
          equipment: exercises.first.equipment,
          scenario: widget.scenario,
          difficulty: result['difficulty']
        ),

        // 3张动作卡
        ...exercises.map((ex) => ExerciseCard(
          exercise: ex,
          onReplace: () => showReplaceSheet(ex.id)
        )),

        // 替换候选预览条
        AlternativesPreviewBar(alternatives: alternatives),

        // 底部操作条
        BottomActionBar(
          onStartWorkout: () => navigateToFollowMode(sessionId),
          onRefresh: () => refreshRecommendation()
        )
      ]
    );
  }
}
```

**Performance Optimization**:
- Algorithm execution: <2s
- Database query: Use indexes on `primary_muscle`, `difficulty`, `intent_type`
- Caching: Redis cache for frequently requested combinations
- Offline support: Pre-load 10 common scenarios locally


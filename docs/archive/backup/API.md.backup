**Frontend Usage**:
```dart
// MyPage - Cards Tab
class CardsAlbumTab extends StatefulWidget {
  @override
  _CardsAlbumTabState createState() => _CardsAlbumTabState();
}

class _CardsAlbumTabState extends State<CardsAlbumTab> {
  List<ShareCard> cards = [];
  String? rarityFilter;
  String? seriesFilter;

  @override
  void initState() {
    super.initState();
    loadCards();
  }

  Future<void> loadCards() async {
    var query = supabase
      .from('share_cards')
      .select('*')
      .eq('user_id', currentUserId)
      .order('created_at', ascending: false);

    // 应用筛选
    if (rarityFilter != null) {
      query = query.eq('rarity', rarityFilter);
    }
    if (seriesFilter != null) {
      query = query.eq('equipment_series', seriesFilter);
    }

    final response = await query;

    setState(() {
      cards = response.map((json) => ShareCard.fromJson(json)).toList();
    });
  }

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        // 筛选栏
        FilterBar(
          rarityFilter: rarityFilter,
          seriesFilter: seriesFilter,
          onRarityChanged: (value) {
            setState(() => rarityFilter = value);
            loadCards();
          },
          onSeriesChanged: (value) {
            setState(() => seriesFilter = value);
            loadCards();
          }
        ),

        // 卡片网格
        GridView.builder(
          gridDelegate: SliverGridDelegateWithFixedCrossAxisCount(
            crossAxisCount: 3,
            childAspectRatio: 104 / 156,
            mainAxisSpacing: 12,
            crossAxisSpacing: 12
          ),
          itemCount: cards.length,
          itemBuilder: (ctx, i) => CardThumbnail(
            card: cards[i],
            onTap: () => showCardDetail(cards[i])
          )
        )
      ]
    );
  }
}
```


    {
      "id": "session-456",
      "userId": "user-123",
      "status": "COMPLETED",
      "intentType": "STRETCH",
      "difficulty": "BEGINNER",
      "scenario": "office",
      "startedAt": "2024-10-30T10:30:00Z",
      "completedAt": "2024-10-30T10:33:00Z",
      "actualDurationSec": 180,
      "completedExerciseCount": 3,
      "skippedExerciseCount": 0,
      "userFeedback": "GOOD",
      "sessionExercises": [
        {
          "exerciseId": "ex-001",
          "position": 1,
          "completedSets": 1,
          "actualDurationSec": 60,
          "exercise": {

// 设置页面
class SettingsTab extends StatelessWidget {
  Future<void> updateSetting(String key, dynamic value) async {
    await supabase
      .from('users')
      .update({key: value})
      .eq('id', currentUserId);

    showSnackBar('Settings updated');
  }

  @override
  Widget build(BuildContext context) {
    return ListView(
      children: [
        // 通知设置
        SwitchListTile(
          title: Text('Streak Reminder'),
          value: user.streakReminder,
          onChanged: (value) => updateSetting('streak_reminder', value)
        ),

        // 隐私设置
        SwitchListTile(
          title: Text('Hide Real Photos'),
          subtitle: Text('Use illustrations instead of photos'),
          value: user.hideRealPhotos,
          onChanged: (value) => updateSetting('hide_real_photos', value)
        ),

        // 语言设置
        ListTile(
          title: Text('Language'),
          subtitle: Text(user.language),
          onTap: () => showLanguagePicker()
        )
      ]
    );
  }
}

**Frontend Usage**:
```dart
// 卡片详情 Bottom Sheet
showCardDetail(ShareCard card) {
  showModalBottomSheet(
    context: context,
    isScrollControlled: true,
    builder: (ctx) => DraggableScrollableSheet(
      initialChildSize: 0.7,
      builder: (ctx, scrollController) => CardDetailSheet(
        card: card,
        onReplay: () => replayWorkout(card.sessionId),
        onShare: () => shareCard(card)
      )
    )
  );
}

// 一键同款
Future<void> replayWorkout(String sessionId) async {
  final session = await supabase
    .from('workout_sessions')
    .select('*, session_exercises(*, exercise(*))')
    .eq('id', sessionId)
    .single();

  // 复刻相同条件
  navigateToResultPage(
    intent: session['intent_type'],
    equipment: session['equipment'],
    scenario: session['scenario']
  );
}
```


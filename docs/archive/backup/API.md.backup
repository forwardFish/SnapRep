### 5.5 Get Daily Training Stats (获取每日统计)

**用途**: 获取每日训练聚合数据 (用于月历视图)

```typescript
GET /rest/v1/daily_trainings?userId=eq.{userId}&date=gte.2024-10-01&date=lte.2024-10-31
```

**Implementation**: Supabase Auto REST API

**Response**:
```json
{
  "data": [
    {
      "id": "daily-001",
      "userId": "user-123",
      "date": "2024-10-29",
      "totalSessions": 2,
      "totalDurationSec": 360,
      "totalExercises": 6,
      "completedExercises": 6,
      "primaryDifficulty": "BEGINNER",
      "topScenario": "office",
      "topEquipment": ["chair", "wall"],
      "isStreakDay": true,
      "specialTags": ["Silent Mode", "2-Day Streak"]
    },
    {
      "id": "daily-002",
      "userId": "user-123",
      "date": "2024-10-30",
      "totalSessions": 1,
      "totalDurationSec": 180,
      // ...
    }
  ]
}
```

**Frontend Usage**:
```dart
// 月历视图
class CalendarView extends StatefulWidget {
  @override
  _CalendarViewState createState() => _CalendarViewState();
}

class _CalendarViewState extends State<CalendarView> {
  Map<DateTime, DailyTraining> dailyStats = {};
  DateTime selectedDate = DateTime.now();

  Future<void> loadMonthStats(int year, int month) async {
    final startDate = DateTime(year, month, 1);
    final endDate = DateTime(year, month + 1, 0);

    final response = await supabase
      .from('daily_trainings')
      .select('*')
      .eq('user_id', currentUserId)
      .gte('date', startDate.toIso8601String())
      .lte('date', endDate.toIso8601String());

    setState(() {
      dailyStats = Map.fromEntries(
        response.map((json) {
          final training = DailyTraining.fromJson(json);
          return MapEntry(training.date, training);
        })
      );
    });
  }

  @override
  Widget build(BuildContext context) {
    return TableCalendar(
      focusedDay: selectedDate,
      firstDay: DateTime(2020),
      lastDay: DateTime.now(),
      calendarBuilders: CalendarBuilders(
        // 自定义日期标记
        markerBuilder: (ctx, date, events) {
          final stats = dailyStats[date];
          if (stats == null) return null;

          return Row(
            children: [
              // 难度圆点
              Container(
                width: 8,
                height: 8,
                decoration: BoxDecoration(
                  color: getDifficultyColor(stats.primaryDifficulty),
                  shape: BoxShape.circle
                )
              ),
              // 特殊徽标
              if (stats.specialTags.contains('Silent Mode'))
                Icon(Icons.volume_off, size: 12)
            ]
          );
        }
      ),
      onDaySelected: (selectedDay, focusedDay) {
        setState(() => selectedDate = selectedDay);
        showDayDetail(selectedDay);
      }
    );
  }
}
```


# SnapRep isolated runtime E2E test environment example
# Copy to a local, untracked env file only if needed. Do not commit real secrets.
# These defaults target backend/docker-compose.test.yml only.

SNAPREP_RUNTIME_E2E=1
SNAPREP_E2E_ENV=test
SNAPREP_E2E_ALLOW_DB_RESET=1
TEST_DATABASE_URL=postgresql://snaprep_test:snaprep_test@127.0.0.1:55432/snaprep_test
TEST_DIRECT_URL=postgresql://snaprep_test:snaprep_test@127.0.0.1:55432/snaprep_test
SNAPREP_E2E_USER_ID=00000000-0000-4000-8000-0000000002c0
SNAPREP_E2E_USER_EMAIL=stage2c-runtime@snaprep.test
